# Copy this file to `.env` in the same folder (the real `.env` is gitignored).
# Docker Compose loads `.env` automatically and passes `DASHSCOPE_API_KEY` into the backend container.

# Alibaba Cloud DashScope API key (Qwen). Get it from the DashScope console.
# This is NOT your AWS key — it authorizes calls from this app to the LLM API.
DASHSCOPE_API_KEY=your-dashscope-api-key

# Optional — only if you split frontend and API hosts when building the frontend:
# VITE_API_BASE_URL=https://your-api-host:8080
